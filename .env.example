# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Cohere Reranking (optional)
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-fast

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_SSL=false

# Data Paths
INDEX_MANIFEST_PATH=data/checkpoints/active_index.json
CHECKPOINT_DB_PATH=data/checkpoints/checkpoints.sqlite
DEFAULT_DOCUMENT_PATH=data/documents/pralov_malla.pdf

# Chunking and Retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
RETRIEVAL_K=12
RERANK_TOP_N=4
MAX_REWRITE_ATTEMPTS=1
MAX_HISTORY_MESSAGES=8
MAX_UPLOAD_MB=10

# Intent Routing
INTENT_CONFIDENCE_THRESHOLD=0.70
