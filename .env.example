# ── Required ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: Cohere reranking (falls back to vector ranking) ─
# COHERE_API_KEY=your-cohere-api-key-here

# ── Model configuration ──────────────────────────────────
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSIONS=768
# COHERE_RERANK_MODEL=rerank-v4.0-fast

# ── Data paths ────────────────────────────────────────────
# CHROMA_PATH=data/vectorstore
# CHECKPOINT_DB_PATH=data/checkpoints/checkpoints.sqlite
# DEFAULT_DOCUMENT_PATH=data/documents/NIST.AI.100-1.pdf

# ── Chunking and retrieval ────────────────────────────────
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=180
# RETRIEVAL_K=12
# RERANK_TOP_N=4
# MAX_REWRITE_ATTEMPTS=1
# MAX_HISTORY_MESSAGES=8
# MAX_UPLOAD_MB=10
